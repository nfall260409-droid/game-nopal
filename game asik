<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Website Keren</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      background:linear-gradient(135deg,#667eea,#764ba2);
      color:white;
      overflow-x:hidden;
    }

    nav{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:20px 8%;
      position:fixed;
      width:100%;
      top:0;
      backdrop-filter:blur(12px);
      background:rgba(255,255,255,.08);
      z-index:1000;
    }

    nav h2{
      color:#fff;
    }

    nav ul{
      display:flex;
      list-style:none;
      gap:25px;
    }

    nav a{
      color:white;
      text-decoration:none;
      transition:.3s;
    }

    nav a:hover{
      color:#ffd54f;
    }

    .hero{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      flex-direction:column;
      text-align:center;
      padding:20px;
    }

    .hero h1{
      font-size:60px;
      margin-bottom:15px;
      animation:fadeDown 1s;
    }

    .hero p{
      max-width:650px;
      opacity:.9;
      margin-bottom:30px;
      animation:fadeUp 1.2s;
    }

    .btn{
      display:inline-block;
      padding:15px 35px;
      background:#ffb703;
      color:#222;
      text-decoration:none;
      font-weight:bold;
      border-radius:50px;
      transition:.3s;
      box-shadow:0 10px 25px rgba(0,0,0,.2);
    }

    .btn:hover{
      transform:translateY(-5px) scale(1.05);
      background:white;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
      padding:80px 8%;
    }

    .card{
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.2);
      backdrop-filter:blur(15px);
      border-radius:20px;
      padding:30px;
      transition:.4s;
      text-align:center;
    }

    .card:hover{
      transform:translateY(-10px);
      background:rgba(255,255,255,.2);
    }

    .card h3{
      margin:15px 0;
    }

    .emoji{
      font-size:50px;
    }

    footer{
      text-align:center;
      padding:25px;
      background:rgba(0,0,0,.2);
    }

    .circle{
      position:fixed;
      width:300px;
      height:300px;
      border-radius:50%;
      filter:blur(120px);
      z-index:-1;
    }

    .c1{
      background:#ff4ecd;
      top:-100px;
      left:-100px;
    }

    .c2{
      background:#00e5ff;
      bottom:-100px;
      right:-100px;
    }

    @keyframes fadeDown{
      from{
        opacity:0;
        transform:translateY(-40px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    @keyframes fadeUp{
      from{
        opacity:0;
        transform:translateY(40px);
      }
      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    @media(max-width:768px){

      .hero h1{
        font-size:40px;
      }

      nav{
        flex-direction:column;
        gap:15px;
      }

    }
  </style>
</head>
<body>

<div class="circle c1"></div>
<div class="circle c2"></div>

<nav>
  <h2>🚀 MyWebsite</h2>

  <ul>
    <li><a href="#">Home</a></li>
    <li><a href="#">Tentang</a></li>
    <li><a href="#">Project</a></li>
    <li><a href="#">Kontak</a></li>
  </ul>
</nav>

<section class="hero">

  <h1>Selamat Datang 👋</h1>

  <p>
    Website modern dengan desain Glassmorphism,
    animasi halus, responsive, dan tampilan yang
    keren untuk portfolio maupun landing page.
  </p>

  <a href="#" class="btn">Mulai Sekarang</a>

</section>

<section class="cards">

  <div class="card">
    <div class="emoji">⚡</div>
    <h3>Cepat</h3>
    <p>Desain ringan dan nyaman digunakan di berbagai perangkat.</p>
  </div>

  <div class="card">
    <div class="emoji">🎨</div>
    <h3>Modern</h3>
    <p>Warna menarik dengan efek glassmorphism yang elegan.</p>
  </div>

  <div class="card">
    <div class="emoji">📱</div>
    <h3>Responsive</h3>
    <p>Tampil sempurna di desktop, tablet, maupun smartphone.</p>
  </div>

</section>

<footer>
  © 2026 MyWebsite • Dibuat dengan ❤️ HTML & CSS
</footer>

<script>
const btn = document.querySelector(".btn");

btn.addEventListener("click", function(e){
  e.preventDefault();

  alert("Terima kasih sudah mengunjungi website ini! 🎉");
});
</script>

</body>
</html>
